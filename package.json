{
  "name": "sodialog",
  "version": "0.1.13",
  "description": "A reusable HTML5 dialog-based modal and offcanvas library.",
  "keywords": [
    "dialog",
    "modal",
    "offcanvas",
    "typescript",
    "html5"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sohophp/sodialog"
  },
  "homepage": "https://github.com/sohophp/sodialog",
  "bugs": {
    "url": "https://github.com/sohophp/sodialog/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/sodialog.es.js",
  "module": "./dist/sodialog.es.js",
  "types": "./dist/types/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/lib.d.ts",
      "import": "./dist/sodialog.es.js",
      "default": "./dist/sodialog.es.js"
    },
    "./style.css": "./dist/sodialog.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "build:demo": "vite build --mode demo",
    "release:check": "node scripts/check-release-version.mjs",
    "docs:changelog": "node scripts/generate-changelog.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
